DATABASE_URL="postgresql://kabata:kabata123@localhost:5433/melaki_store?schema=public"

# Max connections Prisma's pg pool holds open per running instance. Defaults
# to 1 if unset, which is too low for production — concurrent requests on the
# same instance will queue behind each other. Set explicitly in production
# (5-10 is reasonable behind a pooled connection string like Supabase's).
DATABASE_POOL_SIZE=5

# Optional — only needed locally to run `prisma migrate dev` or `prisma migrate diff`.
# Never used by `prisma migrate deploy` (what production runs), so leave unset in
# production. Point this at a scratch schema/database, never at real data —
# Prisma freely drops and recreates whatever this URL points to.
SHADOW_DATABASE_URL=

# NextAuth — generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="generate_a_random_secret_here"
NEXTAUTH_URL="http://localhost:3000"
APP_ENV=local
NEXT_PUBLIC_APP_ENV=local

# Admin seed credentials — MUST be changed before first run
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="change_me_before_first_run"

# M-Pesa Daraja Configuration
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=change_me_before_running
MPESA_CONSUMER_SECRET=change_me_before_running
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=http://localhost:3000/api/payments/callback
MPESA_CALLBACK_SECRET=

# Email Notifications (Resend)
RESEND_API_KEY=
STORE_FROM_EMAIL=orders@melaki.co.ke
ADMIN_NOTIFICATION_EMAIL=admin@melaki.co.ke
# Optional — recipient override for `npx tsx scripts/test-email.ts`. Falls
# back to ADMIN_NOTIFICATION_EMAIL if unset; not used by the running app.
TEST_CUSTOMER_EMAIL=

# Cloudinary — required for admin product/category image uploads.
# Get these from https://console.cloudinary.com/app/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMS Notifications — optional. Defaults to a mock provider that logs instead
# of sending. Set SMS_ENABLED=true and SMS_PROVIDER to a real provider name
# once lib/sms/provider.ts has a real adapter implemented for it.
SMS_ENABLED=false
SMS_PROVIDER=mock

# Optional — only needed if you choose to also trigger cleanup via an
# external scheduler (see docs/DEPLOYMENT.md "Optional: external scheduler").
# The app does NOT depend on any scheduled job by default; stale-order
# cleanup runs opportunistically during normal traffic. Required only to
# authenticate /api/cron/* routes if you do wire one up.
CRON_SECRET=

# Hours a PENDING order with no successful payment is allowed to sit before
# cleanup cancels it and restores its reserved stock.
ORDER_PENDING_TIMEOUT_HOURS=4

# Minimum minutes between opportunistic stale-order cleanup runs. Cleanup is
# triggered by normal traffic (checkout, payment initiation, admin pages) but
# throttled to at most once per this interval so it isn't scanning orders on
# every single request.
ORDER_CLEANUP_INTERVAL_MINUTES=60

# Minimum minutes between opportunistic abandoned-cart reminder checks.
# Triggered by normal storefront/checkout/admin traffic, throttled the same
# way as ORDER_CLEANUP_INTERVAL_MINUTES above.
ABANDONED_CART_CHECK_INTERVAL_MINUTES=60

# Sentry Monitoring
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
SENTRY_TRACES_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

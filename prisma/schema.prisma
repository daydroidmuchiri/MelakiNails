// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Category {
  id           String    @id @default(cuid())
  name         String    @unique
  slug         String    @unique
  image        String?
  displayOrder Int       @default(0)
  active       Boolean   @default(true)
  products     Product[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("categories")
}

model Product {
  id                String      @id @default(cuid())
  name              String
  slug              String      @unique
  description       String?
  price             Decimal     @db.Decimal(10, 2)
  originalPrice     Decimal?    @db.Decimal(10, 2)
  images            String[]
  sku               String?     @unique
  stock             Int         @default(100)
  lowStockThreshold Int         @default(5)
  active            Boolean     @default(true)
  featured          Boolean     @default(false)
  categoryId        String
  category          Category    @relation(fields: [categoryId], references: [id])
  badge             String?
  rating            Float       @default(0)
  reviewCount       Int         @default(0)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  orderItems        OrderItem[]
  wishlistItems     WishlistItem[]
  reviews           Review[]

  @@index([categoryId])
  @@index([active])
  @@index([featured])
  @@map("products")
}

model Order {
  id            String               @id @default(cuid())
  customerName  String
  email         String?
  phone         String
  address       String
  total         Decimal              @db.Decimal(10, 2)
  notes         String?
  trackingToken String               @unique @default(cuid())
  couponId      String?
  couponCode    String?
  discountTotal Decimal              @default(0) @db.Decimal(10, 2)
  deliveryFee   Decimal              @default(0) @db.Decimal(10, 2)
  status        OrderStatus          @default(PENDING)
  coupon        Coupon?              @relation(fields: [couponId], references: [id], onDelete: SetNull)
  statusHistory OrderStatusHistory[]
  payments      Payment[]
  items         OrderItem[]
  couponUsages  CouponUsage[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@index([email])
  @@index([trackingToken])
  @@index([couponId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())

  @@map("order_status_history")
}

model Payment {
  id             String        @id @default(cuid())
  orderId        String
  order          Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  amount            Decimal       @db.Decimal(10, 2)
  paymentMethod     String
  transactionRef    String?       @unique
  status            PaymentStatus @default(PENDING)
  checkoutRequestId String?       @unique
  merchantRequestId String?
  mpesaReceipt      String?
  phoneNumber       String?
  resultCode        Int?
  resultDesc        String?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("payments")
}

model Promotion {
  id                 String   @id @default(cuid())
  title              String
  description        String?
  discountPercentage Float
  active             Boolean  @default(true)
  startDate          DateTime
  endDate            DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([active])
  @@index([startDate])
  @@index([endDate])
  @@map("promotions")
}

model StoreSettings {
  id                   String   @id @default("singleton")
  storeName            String   @default("MELAKI")
  phone                String   @default("+254 700 000 000")
  phone2               String?
  email                String   @default("info@melaki.co.ke")
  address              String   @default("Nairobi, Kenya")
  facebook             String?
  instagram            String?
  twitter              String?
  youtube              String?
  whatsapp             String?
  hours                String   @default("Mon - Sat: 8:00 AM - 6:00 PM")
  emailSender          String   @default("orders@melaki.co.ke")
  emailNotification    String   @default("admin@melaki.co.ke")
  emailCustomerEnabled Boolean  @default(true)
  emailAdminEnabled    Boolean  @default(true)
  smsProvider          String   @default("mock")
  smsSenderId          String?
  smsAdminEnabled      Boolean  @default(false)
  smsCustomerEnabled   Boolean  @default(false)
  minimumStock         Int      @default(5)
  updatedAt            DateTime @updatedAt

  @@map("store_settings")
}

model EmailLog {
  id         String   @id @default(cuid())
  recipient  String
  subject    String
  type       String
  status     String
  error      String?
  createdAt  DateTime @default(now())

  @@index([recipient])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("email_logs")
}

model Coupon {
  id                 String        @id @default(cuid())
  code               String        @unique
  description        String?
  percentageDiscount Float?
  fixedDiscount      Decimal?      @db.Decimal(10, 2)
  minimumOrder       Decimal?      @db.Decimal(10, 2)
  expiryDate         DateTime?
  usageLimit         Int?
  perCustomerLimit   Int?          @default(1)
  freeShipping       Boolean       @default(false)
  active             Boolean       @default(true)
  orders             Order[]
  usages             CouponUsage[]
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([active])
  @@index([expiryDate])
  @@map("coupons")
}

model CouponUsage {
  id             String   @id @default(cuid())
  couponId       String
  coupon         Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customerEmail  String?
  customerPhone  String?
  discountAmount Decimal  @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  @@index([couponId])
  @@index([customerEmail])
  @@index([customerPhone])
  @@map("coupon_usages")
}

model Wishlist {
  id            String         @id @default(cuid())
  customerEmail String?
  sessionId     String?
  items         WishlistItem[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([customerEmail])
  @@index([sessionId])
  @@map("wishlists")
}

model WishlistItem {
  id         String   @id @default(cuid())
  wishlistId String
  productId  String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([wishlistId, productId])
  @@index([productId])
  @@map("wishlist_items")
}

model Review {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerName     String
  customerEmail    String?
  rating           Int
  title            String
  comment          String
  verifiedPurchase Boolean  @default(false)
  approved         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([productId])
  @@index([approved])
  @@map("reviews")
}

model SmsLog {
  id        String   @id @default(cuid())
  recipient String
  message   String
  type      String
  provider  String
  status    String
  error     String?
  createdAt DateTime @default(now())

  @@index([recipient])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("sms_logs")
}

model CartSession {
  id              String              @id @default(cuid())
  sessionId       String              @unique
  email           String?
  phone           String?
  items           CartSessionItem[]
  status          CartReminderStatus  @default(PENDING)
  reminderSentAt  DateTime?
  recoveredOrderId String?
  lastActivityAt  DateTime            @default(now())
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([email])
  @@index([status])
  @@index([lastActivityAt])
  @@map("cart_sessions")
}

model CartSessionItem {
  id            String      @id @default(cuid())
  cartSessionId String
  cartSession   CartSession @relation(fields: [cartSessionId], references: [id], onDelete: Cascade)
  productId     String
  name          String
  price         Decimal     @db.Decimal(10, 2)
  quantity      Int
  image         String?
  slug          String

  @@index([cartSessionId])
  @@map("cart_session_items")
}

enum OrderStatus {
  PENDING
  PROCESSING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
  CANCELLED
  TIMEOUT
}

enum CartReminderStatus {
  PENDING
  SENT
  RECOVERED
  EXPIRED
}

model AdminUser {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String?
  role                AdminRole @default(ADMIN)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@map("admin_users")
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

// Small internal key-value store for system-level state that isn't customer
// or store-facing config (e.g. the lazy-cleanup throttle timestamp in
// lib/orders/cleanupThrottle.ts). Deliberately separate from StoreSettings,
// which holds admin-editable storefront configuration.
model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
